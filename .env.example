# 複製本檔為 .env 並填入實際值:  cp .env.example .env
#
# --- Langfuse self-host 認證(在 UI 的 Project Settings 產生 API keys)---
# public key:識別「哪個 project」,可公開;會被 SDK 附在每筆送出的資料上。
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxx
# secret key:證明「你有權寫入這個 project」,等同密碼,絕不可外流 / commit。
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxx
# host:資料要送到哪個 Langfuse 實例。self-host 指向本機 docker compose。
LANGFUSE_HOST=http://localhost:3000

# --- OpenAI ---
OPENAI_API_KEY=sk-xxxxxxxx
# 練習預設用便宜的小模型;想換模型改這裡即可。
OPENAI_MODEL=gpt-4o-mini
